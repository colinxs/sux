{
  "name": "sux",
  "version": "0.4.0",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath scripts/hooks || true; git config merge.ours.driver true || true",
    "deploy": "wrangler deploy --config sux/wrangler.jsonc",
    "deploy:sux": "wrangler deploy --config sux/wrangler.jsonc",
    "secret:sux": "wrangler secret put --config sux/wrangler.jsonc",
    "dev": "wrangler dev --config sux/wrangler.jsonc",
    "start": "wrangler dev --config sux/wrangler.jsonc",
    "cf-typegen": "wrangler types --config sux/wrangler.jsonc",
    "type-check": "tsc --noEmit",
    "test": "vitest run --config sux/vitest.config.ts",
    "test:sux": "vitest run --config sux/vitest.config.ts",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config sux/test/e2e/vitest.e2e.config.ts",
    "docs": "node sux/scripts/gen-docs.mjs",
    "wiki": "node scripts/gen-wiki.mjs",
    "check:wiki": "node scripts/gen-wiki.mjs --check",
    "gen:index": "node sux/scripts/gen-index.mjs",
    "gen:skill": "node sux/scripts/gen-skill-prompt.mjs",
    "check:skills": "node scripts/check-skill-sync.mjs",
    "sync:skills": "node scripts/check-skill-sync.mjs --write",
    "build:node": "node sux/node/build-deploy.mjs",
    "check:node": "node sux/node/build-deploy.mjs --check",
    "check:wrangler-compat": "node scripts/check-wrangler-compat-drift.mjs",
    "bench:costs": "node sux/scripts/benchmark-costs.mjs",
    "check:pricing": "node sux/scripts/check-pricing.mjs",
    "lint:dispatcher-docs": "node sux/scripts/lint-dispatcher-param-docs.mjs",
    "branches": "bash scripts/branch-sweep.sh",
    "ci": "npm run type-check && npm test && npm run check:node && npm run check:wrangler-compat && npm run gen:index && git diff --exit-code sux/src/fns/index.ts && wrangler deploy --dry-run --config sux/wrangler.jsonc"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/workers-oauth-provider": "^0.8.1",
    "@ghostery/adblocker": "^2.18.1",
    "fflate": "^0.8.3",
    "pdf-lib": "^1.17.1",
    "tldts-experimental": "^7.4.8"
  },
  "devDependencies": {
    "typescript": "7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
