{
  "apiVersion": 1,
  "groups": [
    {
      "orgId": 1,
      "name": "sux-resilience",
      "folder": "sux",
      "interval": "1m",
      "rules": [
        {
          "uid": "sux-error-ratio-high",
          "title": "sux error ratio sustained high",
          "condition": "C",
          "for": "10m",
          "noDataState": "OK",
          "execErrState": "Error",
          "annotations": {
            "summary": "sux worker error ratio has been above 5% for 10m",
            "description": "The fraction of {service=\"sux\"} calls with error=true (from the Loki JSON log line) has stayed above 5% for 10 minutes. Check the 'Errors by tool' panel on the 'sux — resilience & observability' dashboard to attribute the spike, then inspect the offending tool's err values.",
            "runbook_url": ""
          },
          "labels": {
            "service": "sux",
            "severity": "warning"
          },
          "data": [
            {
              "refId": "A",
              "relativeTimeRange": { "from": 600, "to": 0 },
              "datasourceUid": "${DS_LOKI}",
              "model": {
                "refId": "A",
                "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
                "queryType": "instant",
                "editorMode": "code",
                "expr": "sum(rate({service=\"sux\"} | json | error=`true` [5m])) / sum(rate({service=\"sux\"}[5m]))",
                "intervalMs": 1000,
                "maxDataPoints": 43200
              }
            },
            {
              "refId": "B",
              "relativeTimeRange": { "from": 600, "to": 0 },
              "datasourceUid": "__expr__",
              "model": {
                "refId": "B",
                "datasource": { "type": "__expr__", "uid": "__expr__" },
                "type": "reduce",
                "reducer": "last",
                "expression": "A"
              }
            },
            {
              "refId": "C",
              "relativeTimeRange": { "from": 600, "to": 0 },
              "datasourceUid": "__expr__",
              "model": {
                "refId": "C",
                "datasource": { "type": "__expr__", "uid": "__expr__" },
                "type": "threshold",
                "expression": "B",
                "conditions": [
                  {
                    "type": "query",
                    "evaluator": { "type": "gt", "params": [0.05] },
                    "operator": { "type": "and" },
                    "query": { "params": ["B"] },
                    "reducer": { "type": "last", "params": [] }
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
