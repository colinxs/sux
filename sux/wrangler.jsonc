{
	"$schema": "../node_modules/wrangler/config-schema.json",
	"name": "sux",
	"main": "src/index.ts",
	"compatibility_date": "2026-07-16",
	// global_fetch_strictly_public: forces global fetch() onto the public internet
	// only — private/internal/loopback/link-local targets are refused at the platform
	// level, and same-account Worker fetches loop through the public front door. This
	// enables CIMD (Client ID Metadata Document) in the OAuth/MCP client flow. Pure
	// defense-in-depth here: every sux egress already targets a public host (external
	// APIs, the .ts.net Tailscale Funnel URLs resolve to public IPs), and smartFetch's
	// isBlockedTarget/isPrivateIp guards already refuse private targets in app code.
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	// KV: OAuth state + tool-result cache (same scheme as the core Worker).
	"kv_namespaces": [{ "binding": "OAUTH_KV", "id": "d0dadc11fdd64598992f4a84a958bafb" }],
	// Workers AI — edge inference for summarize/translate/classify/embed/ocr (~300× cheaper).
	// AI Gateway routing (#1060, improvement-backlog.md item 9) is configured entirely
	// out-of-band, NOT declared here (like MONARCH_TOKEN / OBSIDIAN_VAULT_REPO): set the
	// AI_GATEWAY_ID secret (`wrangler secret put`) once a human creates the gateway in
	// the Cloudflare account. Absent ⇒ every env.AI.run() call behaves exactly as it does
	// today (ai.ts's aiGatewayOptions() passes no gateway option); no call-site changes
	// needed to arm it later.
	"ai": { "binding": "AI" },
	// Cloudflare Images — format convert/resize/adjust for image_convert.
	"images": { "binding": "IMAGES" },
	// R2 object storage for `store` (content-addressed blobs; KV maps uuid→object).
	"r2_buckets": [{ "binding": "R2", "bucket_name": "sux-mcp" }],
	// Workers Analytics Engine (#220) — durable, SQL-queryable event log for cron
	// heartbeats, mail-triage decisions, and self-improve findings, replacing "grep
	// wrangler tail" as the only way to answer e.g. "which cron sub-job fails most
	// often." Bind-only: unlike Cloudflare Pipelines (needs a separately-provisioned
	// R2/Iceberg destination via `wrangler pipelines create`), an Analytics Engine
	// dataset is auto-provisioned on first write once this binding is deployed — no
	// extra account-level resource creation needed.
	"analytics_engine_datasets": [{ "binding": "ANALYTICS", "dataset": "sux_events" }],
	// Durable op runtime — the `run` front-verb starts OpWorkflow instances that
	// interpret a suxlib Op tree step-by-step, so a run survives isolate eviction,
	// step retries, and multi-day human (ask) pauses. See src/op-engine/durable.ts.
	"workflows": [{ "name": "op-workflow", "binding": "OP_WORKFLOW", "class_name": "OpWorkflow" }],
	// Browser Run (Cloudflare renamed "Browser Rendering" -> "Browser Run" Apr 2026 —
	// same `browser` binding shape and `@cloudflare/puppeteer` package, purely additive:
	// CDP endpoint, WebMCP, session recordings, 30->120 concurrency) — headless Chromium
	// for `render` (JS-rendered scraping). NOTE: egresses from the CF datacenter, not the
	// residential proxy.
	"browser": { "binding": "BROWSER" },
	// QUIC/HTTP-3 is automatic at the edge; observability = persistent logs (both services).
	"observability": { "enabled": true, "head_sampling_rate": 1 },
	// Cron Triggers → the scheduled() handler in src/index.ts. The daily 13:00 UTC tick
	// runs the full best-effort maintenance (Kroger token warm, mail triage, adblock,
	// metrics snapshot). The */5 tick pushes ONLY the Grafana Cloud Prometheus metrics
	// snapshot (dormant until GRAFANA_PROM_* are set) so the gauges refresh every 5 min
	// instead of once a day. scheduled() branches on event.cron (METRICS_CRON).
	"triggers": { "crons": ["0 13 * * *", "*/5 * * * *"] },
	// MAIL_TRIAGE_ENABLED arms the classify+suggest+digest loop (suggest-only: it classifies and
	// writes the daily digest but MUTATES NOTHING). MAIL_TRIAGE_ACT is deliberately NOT set here —
	// Colin flips it (dashboard/secret) to move from suggest-only to acting on the reversible-only
	// allow-list (label/archive/unarchive/undelete). Escape hatch: unset MAIL_TRIAGE_ENABLED (whole
	// feature dormant) or run mail_triage {action:"undo", cycle_id} to reverse a cycle.
	//
	// WEEKLY_RECALL_ENABLED arms the once-per-ISO-week recall digest: standing questions run through
	// recall (READ-only cross-store fan-out) and the ONLY write is a git-reversible vault append to
	// Weekly/<week>.md — no mailbox, no external surface, strictly less privileged than mail triage.
	//
	// SELF_IMPROVE_ENABLE arms the feedback loop in REVIEW-ONLY mode: it reads the issue/suggest
	// backlog and records findings to KV, opening NOTHING outward. Outward PRs stay gated behind
	// SELF_IMPROVE_PR="on" + GITHUB_TOKEN (both deliberately NOT set here), so this flag alone acts
	// on nothing. SELF_IMPROVE_KILL (secret) hard-stops the whole loop even when enabled.
	//
	// BRIEFING_ENABLED is deliberately NOT set here — pending H1 (untrusted mail through the llm()
	// fence); arm it once that fix lands.
	//
	// LIFE_WIKI_ENABLED gates the life-learning living wiki (fns/_life_wiki.ts). Ships "0" = OFF:
	// the daily cron tick is a total no-op until flipped to "1". Safe to arm — writes ONLY into the
	// sandboxed vault subdir (sux/wiki/), never the user's own notes; that subdir is deletable.
	//
	// MyChart (Epic SMART-on-FHIR) + Apple Health ingest are configured entirely by
	// out-of-band secrets, NOT declared here (like MONARCH_TOKEN / KROGER_* / the
	// SELF_IMPROVE_* secrets): EPIC_CLIENT_ID, EPIC_CLIENT_SECRET, EPIC_FHIR_BASE
	// (`wrangler secret put …`) arm the mychart fn + /mychart/connect|callback routes;
	// HEALTH_INGEST_TOKEN arms POST /apple-health. All absent ⇒ inert (not_configured),
	// the routes 404. The durable Epic REFRESH token is NOT a secret — it's minted at
	// /mychart/callback and held in OAUTH_KV (sux:mychart:grant). See src/mychart.ts.
	"vars": { "DEBUG_MCP": "0", "MAIL_TRIAGE_ENABLED": "1", "WEEKLY_RECALL_ENABLED": "1", "SELF_IMPROVE_ENABLE": "1", "LIFE_WIKI_ENABLED": "0" },
	// Per-user rate limit (same as core).
	"unsafe": {
		"bindings": [
			{ "name": "MCP_RATE_LIMITER", "type": "ratelimit", "namespace_id": "2001", "simple": { "limit": 600, "period": 60 } },
			// Coarse per-IP ceiling for the anonymous observability/content routes (/metrics, /logs,
			// /feedback, /s/*) — the MCP gate never sees these, so this is their only backpressure.
			{ "name": "OBS_RATE_LIMITER", "type": "ratelimit", "namespace_id": "2002", "simple": { "limit": 300, "period": 60 } }
		]
	},
	"dev": { "port": 8789 },
	"upload_source_maps": true
}
