#!/bin/sh
# Living-wiki: on every commit, regenerate the knowledge artifacts from source
# and re-stage them so the wiki never drifts from the code you're committing.
#   sux/FUNCTIONS.md              <- sux/src/fns/*.ts   (npm run docs)
#   docs/wiki/MOCs/Functions-MOC  <- FUNCTIONS.md       (npm run wiki)
#   docs/wiki/MOCs/Status-Dashboard <- doc frontmatter  (npm run wiki)
#   llms.txt                      <- the whole vault    (npm run wiki)
#
# Installed by `npm run prepare` (sets core.hooksPath=scripts/hooks).
# Best-effort: a tooling hiccup warns but never blocks the commit — CI is the
# real gate. See docs/wiki/Meta/wiki-protocol.md.

root="$(git rev-parse --show-toplevel)" || exit 0
cd "$root" || exit 0

# No npm (odd environment, rebase bot, …) → don't block the commit.
command -v npm >/dev/null 2>&1 || exit 0

echo "· living-wiki: regenerating knowledge artifacts…"
npm run docs --silent >/dev/null 2>&1 || echo "  (npm run docs failed — leaving FUNCTIONS.md as-is)"
npm run wiki --silent >/dev/null 2>&1 || echo "  (npm run wiki failed — leaving wiki notes as-is)"

git add -- \
  sux/FUNCTIONS.md \
  docs/wiki/MOCs/Functions-MOC.md \
  docs/wiki/MOCs/Status-Dashboard.md \
  llms.txt >/dev/null 2>&1 || true

exit 0
